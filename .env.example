# PaperRAG Configuration
# Copy this file to .env and fill in your values

# --- Paths ---
# PAPERRAG_DATA_DIR=data
# PAPERRAG_INDEX_DIR=indexes

# --- Embedding ---
# PAPERRAG_EMBEDDING_PROVIDER=local
# PAPERRAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# PAPERRAG_EMBEDDING_DIM=384

# For API embedding:
# PAPERRAG_EMBEDDING_PROVIDER=api
# PAPERRAG_EMBEDDING_API_URL=https://api.openai.com/v1
# PAPERRAG_EMBEDDING_API_KEY=sk-xxx
# PAPERRAG_EMBEDDING_MODEL=text-embedding-3-small
# PAPERRAG_EMBEDDING_DIM=1536

# --- LLM ---
PAPERRAG_LLM_PROVIDER=openai_compatible
PAPERRAG_LLM_API_URL=https://api.openai.com/v1
PAPERRAG_LLM_API_KEY=sk-xxx
PAPERRAG_LLM_MODEL=gpt-3.5-turbo
# PAPERRAG_LLM_TEMPERATURE=0.1
# PAPERRAG_LLM_MAX_TOKENS=1024

# For Anthropic:
# PAPERRAG_LLM_PROVIDER=anthropic
# PAPERRAG_LLM_API_KEY=sk-ant-xxx
# PAPERRAG_LLM_MODEL=claude-sonnet-4-6

# --- Retrieval ---
# PAPERRAG_TOP_K_DENSE=30
# PAPERRAG_TOP_K_BM25=30
# PAPERRAG_TOP_N_FUSED=20
# PAPERRAG_TOP_N_FINAL=10
# PAPERRAG_TOP_N_CONTEXT=5
# PAPERRAG_FUSION_STRATEGY=rrf

# --- Reranker ---
# PAPERRAG_RERANK_ENABLED=false
# PAPERRAG_RERANKER_PROVIDER=none

# --- API ---
# PAPERRAG_API_HOST=0.0.0.0
# PAPERRAG_API_PORT=8000
